for (var i = 0; i <= 3; i++) {
  console.log(i);
}
console.log("i =", i); // Imprime: i = 4 - A variável i é acessível fora do loop, pois var tem escopo global ou de função, e não de bloco e tem valor 4 pois o loop terminou quando i era igual a 4

for (let iLet = 0; iLet <= 3; iLet++) {
  console.log(iLet);
}
console.log("iLet =", iLet); // ReferenceError: iLet is not defined - iLet não está disponível fora do bloco
